{
  "style_preset": {
    "name": "Invariant Atmospheric Matte Gouache",
    "aspect_ratio": "4:5 vertical",

    "medium": {
      "type": "painterly matte gouache illustration",
      "rendering": [
        "soft atmospheric hand-painted look",
        "visible but refined brushwork",
        "fine paper grain texture",
        "muted premium editorial aesthetic",
        "not 3D",
        "not photoreal",
        "not glossy CGI",
        "not concept-art sci-fi neon"
      ]
    },

    "composition": {
      "top_open_space": "40-70% calm negative space reserved for text overlay",
      "subject_bias": "subject generally positioned right or lower-right",
      "visual_feeling": [
        "immense scale",
        "quiet engineering",
        "restraint",
        "calm precision",
        "solitude",
        "atmospheric depth"
      ],
      "camera_language": [
        "distant cinematic framing",
        "minimal clutter",
        "soft horizon separation",
        "large empty sky",
        "gentle perspective compression"
      ]
    },

    "color_palette": {
      "overall_balance": "75% cool / 25% warm",
      "cool_tones": {
        "midnight_navy": "#1B2436",
        "observatory_blue": "#425D77",
        "mineral_grey": "#D9D6D1",
        "cloud_grey": "#ECEAE7"
      },
      "warm_accent": {
        "dusk_copper": "#C57A3E"
      },
      "rules": [
        "keep colors muted and desaturated",
        "avoid vibrant saturation",
        "warm tones should feel restrained and sparse",
        "warm accents only for engine glow, horizon light, signal lights, or reflections"
      ]
    },

    "lighting": {
      "time_of_day": [
        "dusk",
        "blue hour",
        "pre-dawn",
        "night-side orbital glow"
      ],
      "sky_gradient": {
        "top": "#1B2436",
        "middle": "#425D77",
        "horizon_glow": "#C57A3E"
      },
      "atmosphere": [
        "soft volumetric mist",
        "diffused haze",
        "thin atmospheric scattering",
        "subtle glow bloom",
        "low contrast lighting"
      ]
    },

    "environment": {
      "fog_density": "light to moderate",
      "cloud_style": [
        "soft mineral cloud masses",
        "low contrast",
        "gouache-textured",
        "layered atmospheric depth"
      ],
      "terrain_style": [
        "minimal detail",
        "mist-obscured",
        "subdued silhouettes"
      ]
    },

    "subject_treatment": {
      "scale": "small relative to environment",
      "detail_level": "refined but restrained",
      "silhouette_priority": true,
      "avoid": [
        "busy mechanical detailing",
        "harsh highlights",
        "overly dramatic action",
        "chaotic smoke",
        "explosions"
      ]
    },

    "logo_system": {
      "use_uploaded_logo": true,
      "instructions": [
        "place attached Invariant logo in top-left corner",
        "reproduce exactly",
        "do not redraw",
        "do not distort",
        "do not stylize",
        "do not alter proportions"
      ],
      "color": "#ECEAE7",
      "size": {
        "relative_width": "5-7% of canvas width"
      },
      "position": {
        "horizontal_margin": "5-7% from left edge",
        "vertical_margin": "5-7% from top edge"
      },
      "opacity": "100%"
    },

    "scene_language": {
      "approved_elements": [
        "rocket ascent trails",
        "distant boosters",
        "launch towers",
        "satellite constellations",
        "orbital horizons",
        "signal beams",
        "ground stations",
        "mist-covered launch sites",
        "service towers",
        "robotic catch arms"
      ],
      "scene_behavior": [
        "calm and restrained",
        "minimal action",
        "quiet anticipation",
        "engineering elegance",
        "subtle motion"
      ]
    },

    "texture_and_finish": {
      "paper_grain": "fine matte watercolor paper",
      "edge_quality": "soft",
      "contrast": "low to medium",
      "sharpness": "slightly softened",
      "finish": [
        "premium editorial illustration",
        "luxury aerospace brand aesthetic",
        "atmospheric matte painting"
      ]
    },

    "negative_prompt": [
      "photorealism",
      "3D render",
      "plastic textures",
      "oversaturated colors",
      "anime",
      "cyberpunk neon",
      "lens flare abuse",
      "heavy UI",
      "text overlays",
      "logos besides attached logo",
      "explosions",
      "crowded composition",
      "excessive detail",
      "harsh contrast",
      "comic-book styling"
    ]
  }
}
